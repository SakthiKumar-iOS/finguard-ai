# FinGuard AI — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# LLM model — do not change unless upgrading
GEMINI_MODEL=gemini-2.0-flash

# MCP local server — do not expose beyond localhost
MCP_HOST=127.0.0.1
MCP_PORT=8765

# Security flags — keep all true for production use
PII_REDACTION_ENABLED=true
PROMPT_INJECTION_GUARD=true
LOCAL_ONLY_MODE=true

# Auto-resolved from project root — no change needed
DATA_DIR=data
AUDIT_LOG_DIR=data/audit_logs
